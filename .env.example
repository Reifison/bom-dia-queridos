# Server only — never expose in the browser bundle. Use .env.local (gitignored).
# Geração de imagem usa quota própria; se vir 429 no terminal, ative billing em AI Studio ou aguarde reset.
GEMINI_API_KEY=

# API server port (default 8787). Put the same value in .env.local so Vite's dev proxy matches.
API_PORT=8787

# Optional: full origin of the API when the SPA is hosted separately (e.g. https://api.example.com).
# Leave unset when the API is same-origin (recommended: one server serves dist + /api).
#
# OBRIGATÓRIO no .env.local para Capacitor/iOS (senão fetch('/api') aponta para capacitor:// e falha):
# VITE_API_ORIGIN=http://127.0.0.1:8787
# iPhone físico na mesma Wi‑Fi: VITE_API_ORIGIN=http://IP_DO_MAC:8787 — depois npm run ios:sync e npm run start no Mac.
